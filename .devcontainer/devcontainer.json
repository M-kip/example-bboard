{
  "name": "Midnight Dev Environment",

  // 1. Base image with Git and Node.js 22 pre-installed
  "image": "://microsoft.com",

  "features": {
    // 2. Activates Docker inside your container for the Midnight proof server
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    
    // 3. Installs Git LFS into the container toolchain
    "ghcr.io/devcontainers/features/git-lfs:1": {}
  },

  // 4. Installs the Compact compiler and automatically links Git LFS hooks on startup
  "postCreateCommand": "curl --proto '=https' --tlsv1.2 -LsSf https://github.com | sh && git lfs install",

  "customizations": {
    "vscode": {
      "settings": {
        // 5. Ensures VS Code recognizes the new 'compact' compiler command
        "terminal.integrated.env.linux": {
          "PATH": "${env:HOME}/.compact/bin:${env:PATH}"
        }
      }
    }
  },

  // 6. Opens network port 6300 so your applications can contact the proof server
  "forwardPorts": [6300]
}